<?xml version="1.0" encoding="UTF-8" ?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <label>Sync Billing Account Flag</label>
    <processType>AutoLaunchedFlow</processType>
    <status>Active</status>
    <interviewLabel
  >Sync Billing Account Flag {!$Flow.CurrentDateTime}</interviewLabel>
    <description
  >Small utility flow, not one of the 5 named business-process flows in ARCHITECTURE.md. Record-triggered on Billing_Account__c create: sets Account.Has_Billing_Account__c = true on the parent account, since Billing_Account__c.Account__c is a Lookup (not Master-Detail) so no native roll-up is available for the Business-Customer validation rule to check directly.</description>

    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Mark_Account_Has_Billing_Account</targetReference>
        </connector>
        <object>Billing_Account__c</object>
        <triggerType>RecordAfterSave</triggerType>
        <recordTriggerType>Create</recordTriggerType>
    </start>

    <recordUpdates>
        <name>Mark_Account_Has_Billing_Account</name>
        <label>Mark Account Has Billing Account</label>
        <locationX>176</locationX>
        <locationY>130</locationY>
        <inputAssignments>
            <field>Has_Billing_Account__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Account__c</elementReference>
            </value>
        </filters>
        <object>Account</object>
    </recordUpdates>
</Flow>
