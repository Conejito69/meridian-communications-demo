<?xml version="1.0" encoding="UTF-8" ?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>PS_Support_Tier2</fullName>
    <label>Support - Tier 2 Agent</label>
    <description
  >Incremental add-on layered on top of PS_Support_Tier1 inside PSG_Support_Agent_T2: the ability to author Escalation Logs (not just read them) and to delete a Case when a duplicate or test record needs removing — a level of cleanup authority not given to Tier 1.</description>
    <objectPermissions>
        <object>Case</object>
        <allowRead>true</allowRead>
        <allowCreate>false</allowCreate>
        <allowEdit>false</allowEdit>
        <allowDelete>true</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>Escalation_Log__c</object>
        <allowRead>true</allowRead>
        <allowCreate>true</allowCreate>
        <allowEdit>true</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <fieldPermissions>
        <field>Escalation_Log__c.Escalated_From__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Escalation_Log__c.Escalated_To__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Escalation_Log__c.Escalation_Reason__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Escalation_Log__c.Escalated_Date__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <tabSettings>
        <tab>Escalation_Log__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
</PermissionSet>
