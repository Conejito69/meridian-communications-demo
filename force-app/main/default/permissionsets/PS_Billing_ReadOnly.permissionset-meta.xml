    </fieldPermissions>
    <fieldPermissions>
        <field>Service_Subscription__c.Monthly_Recurring_Revenue__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Case.Resolution_Summary__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Case.SLA_Target_DateTime__c</field>
