<?xml version="1.0" encoding="UTF-8" ?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>PS_Provisioning_Manager</fullName>
    <label>Provisioning - Manager</label>
    <description
  >Incremental add-on layered on top of PS_Provisioning_Agent inside PSG_Provisioning_Lead (Permission Set Groups take the union of their members' access, so this set only needs to declare what a manager has beyond an agent): the ability to delete a Provisioning Task, and read-only visibility into Billing Accounts to sanity-check billing readiness before closing out fulfillment.</description>
    <objectPermissions>
        <object>Provisioning_Task__c</object>
        <allowRead>true</allowRead>
        <allowCreate>false</allowCreate>
        <allowEdit>false</allowEdit>
        <allowDelete>true</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>Billing_Account__c</object>
        <allowRead>true</allowRead>
        <allowCreate>false</allowCreate>
        <allowEdit>false</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <fieldPermissions>
        <field>Billing_Account__c.Billing_Contact__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Billing_Account__c.Currency_Code__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <tabSettings>
        <tab>Billing_Account__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
</PermissionSet>
