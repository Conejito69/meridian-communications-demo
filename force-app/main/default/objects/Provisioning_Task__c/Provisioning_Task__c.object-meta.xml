<?xml version="1.0" encoding="UTF-8" ?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Provisioning Task</label>
    <pluralLabel>Provisioning Tasks</pluralLabel>
    <description
  >A discrete fulfillment task generated by the provisioning process for a Service Order, tracked through to completion by the Provisioning team.</description>
    <deploymentStatus>Deployed</deploymentStatus>
    <visibility>Public</visibility>
    <sharingModel>Private</sharingModel>
    <nameField>
        <label>Provisioning Task Number</label>
        <type>AutoNumber</type>
        <displayFormat>PT-{00000}</displayFormat>
        <startingNumber>1</startingNumber>
    </nameField>
    <enableActivities>true</enableActivities>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
</CustomObject>
