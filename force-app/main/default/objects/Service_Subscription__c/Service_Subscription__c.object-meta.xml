<?xml version="1.0" encoding="UTF-8" ?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Service Subscription</label>
    <pluralLabel>Service Subscriptions</pluralLabel>
    <description
  >Represents an active managed service that a customer account currently subscribes to (Internet, Voice, Managed Security, or Cloud Backup), including its recurring revenue value.</description>
    <deploymentStatus>Deployed</deploymentStatus>
    <visibility>Public</visibility>
    <sharingModel>Private</sharingModel>
    <nameField>
        <label>Subscription Number</label>
        <type>AutoNumber</type>
        <displayFormat>SUB-{00000}</displayFormat>
        <startingNumber>1</startingNumber>
    </nameField>
    <enableActivities>true</enableActivities>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
</CustomObject>
