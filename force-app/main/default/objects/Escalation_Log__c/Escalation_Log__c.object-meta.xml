<?xml version="1.0" encoding="UTF-8" ?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Escalation Log</label>
    <pluralLabel>Escalation Logs</pluralLabel>
    <description
  >A historical record of support case escalations, capturing where an issue was escalated from and to, and why.</description>
    <deploymentStatus>Deployed</deploymentStatus>
    <visibility>Public</visibility>
    <sharingModel>Private</sharingModel>
    <nameField>
        <label>Escalation Number</label>
        <type>AutoNumber</type>
        <displayFormat>ESC-{00000}</displayFormat>
        <startingNumber>1</startingNumber>
    </nameField>
    <enableActivities>true</enableActivities>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
</CustomObject>
